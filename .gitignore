# agent evidence & scratch — regenerated per task, never committed
.artifacts/

# go
bin/
*.test

# web
node_modules/
web/build/
web/.svelte-kit/
web/test-results/
web/playwright-report/
web/tests/.auth/

# make demo/dev local state: seeded blob store, built binaries, pids, db url.
# Never committed; `make demo-down` cleans the runtime bits.
.demo/

# embedded web build output — populated by `make build`, never committed
# (the .gitkeep placeholder is kept so `//go:embed all:dist` always resolves)
internal/webembed/dist/*
!internal/webembed/dist/.gitkeep

# local env & secrets
.env
.env.*
*.local

# OS
.DS_Store
